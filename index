// ONBOARDING
// =======================================================
function dismissOnboarding(){document.getElementById('onboarding').classList.remove('open');showView('month')}

// =======================================================
// INIT
// =======================================================
// ═══════════════════════════════════════════════════════
// GARDEN
// ═══════════════════════════════════════════════════════
let gardenSpan='week';
function setGardenSpan(s){
  gardenSpan=s;
  document.querySelectorAll('[data-gspan]').forEach(b=>b.classList.toggle('active',b.dataset.gspan===s));
  renderGarden();
}

function getGardenDays(){
  const today=new Date();
  const days=[];
  if(gardenSpan==='week'){
    for(let i=6;i>=0;i--){
      const d=new Date(today);d.setDate(d.getDate()-i);
      const iso=isoDate(d.getFullYear(),d.getMonth(),d.getDate());
      const name=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];
      days.push({iso,label:name,date:d});
    }
  } else if(gardenSpan==='month'){
    const dim=new Date(viewYear,viewMonth+1,0).getDate();
    for(let d=1;d<=dim;d++){
      const iso=isoDate(viewYear,viewMonth,d);
      days.push({iso,label:String(d),date:new Date(viewYear,viewMonth,d)});
    }
  } else {
    // All time — group by week
    const allDates=Object.keys(log).filter(d=>(log[d]||[]).length).sort();
    allDates.forEach(iso=>{
      const d=new Date(iso+'T12:00:00');
      const name=d.toLocaleDateString('en-GB',{day:'numeric',month:'short'});
      days.push({iso,label:name,date:d});
    });
  }
  return days;
}

function renderGarden(){
  const wrap=document.getElementById('garden-canvas-wrap');
  const canvas=document.getElementById('garden-canvas');
  if(!wrap||!canvas)return;
  const dpr=window.devicePixelRatio||1;
  const W=wrap.clientWidth,H=wrap.clientHeight;
  if(W<10||H<10)return;
  canvas.width=W*dpr;canvas.height=H*dpr;
  canvas.style.width=W+'px';canvas.style.height=H+'px';
  const ctx=canvas.getContext('2d');
  ctx.scale(dpr,dpr);

  // Background
  const grad=ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0,'#f5f0e8');grad.addColorStop(1,'#e8e0cc');
  ctx.fillStyle=grad;ctx.fillRect(0,0,W,H);

  const days=getGardenDays();
  const activeDays=days.filter(d=>(log[d.iso]||[]).length>0);
  if(!activeDays.length){
    ctx.fillStyle='#9c8e7a';ctx.font='12px '+getComputedStyle(document.body).fontFamily;
    ctx.textAlign='center';ctx.fillText('No data yet — start logging pursuits!',W/2,H/2);
    document.getElementById('garden-stat').textContent='';
    return;
  }

  // Bouquet layout
  const handX=W/2, handY=H*0.93;
  const n=activeDays.length;
  const maxSpreadDeg=Math.min(130, 30+n*12);
  const startAngleDeg=-90-maxSpreadDeg/2;

  activeDays.forEach((day,i)=>{
    const entries=log[day.iso]||[];
    // Get unique pursuit colours
    const seen=new Set();const petals=[];
    pursuits.forEach(p=>{if(entries.some(tid=>(typeof tid==='string'?tid:tid.tid)===p.id)&&!seen.has(p.id)){seen.add(p.id);petals.push(p.color)}});
    if(!petals.length)return;

    const angleDeg=n===1?-90:startAngleDeg+(i/(n-1))*maxSpreadDeg;
    const angleRad=angleDeg*Math.PI/180;
    const midness=n===1?1:1-Math.abs((i-(n-1)/2)/((n-1)/2));
    const stemLen=H*(0.38+midness*0.16+(Math.random()*0-0))+rngFlower(day.iso.split('').reduce((a,c)=>a+c.charCodeAt(0),0),99)*H*0.06;
    const flowerX=handX+Math.cos(angleRad)*stemLen;
    const flowerY=handY+Math.sin(angleRad)*stemLen;
    // Slight curve
    const cpX=handX+Math.cos(angleRad)*stemLen*0.55+Math.cos(angleRad+Math.PI/2)*stemLen*0.07*(i%2?1:-1);
    const cpY=handY+Math.sin(angleRad)*stemLen*0.55+Math.sin(angleRad+Math.PI/2)*stemLen*0.07*(i%2?1:-1);

    // Stem
    ctx.beginPath();ctx.moveTo(handX,handY);
    ctx.quadraticCurveTo(cpX,cpY,flowerX,flowerY);
    ctx.strokeStyle='rgba(90,130,60,0.65)';ctx.lineWidth=1.5;ctx.lineCap='round';ctx.stroke();

    // Leaf
    const leafT=0.55;
    const lx=handX+Math.cos(angleRad)*stemLen*leafT;
    const ly=handY+Math.sin(angleRad)*stemLen*leafT;
    const leafAngle=angleRad+(i%2?0.55:-0.55);
    const leafLen=8+petals.length*1.5;
    ctx.save();ctx.translate(lx,ly);ctx.rotate(leafAngle);
    ctx.beginPath();ctx.ellipse(leafLen/2,0,leafLen/2,leafLen*0.22,0,0,Math.PI*2);
    ctx.fillStyle='rgba(110,155,75,0.45)';ctx.fill();ctx.restore();

    // Day label
    const lblT=0.78;
    const lbx=handX+Math.cos(angleRad)*stemLen*lblT;
    const lby=handY+Math.sin(angleRad)*stemLen*lblT;
    ctx.save();ctx.translate(lbx,lby);ctx.rotate(angleRad+Math.PI/2);
    ctx.fillStyle='#9c8e7a';ctx.font=`500 7px var(--mono)`;ctx.textAlign='center';
    ctx.fillText(day.label,0,0);ctx.restore();

    // Draw flower using SVG rendered to canvas via Image
    const sz=18+petals.length*5;
    const seed=day.iso.split('').reduce((a,c,i)=>a+c.charCodeAt(0)*(i+1),0);
    // Draw petals directly on canvas
    petals.forEach((color,pi)=>{
      const a=(pi/petals.length)*Math.PI*2-Math.PI/2;
      const outerR=sz*0.42*(petals.length<=5?1:0.82);
      const tipR=outerR*(0.90+rngFlower(seed,pi)*0.18);
      const tipA=a+(rngFlower(seed,pi+50)-0.5)*0.12;
      const tipX2=flowerX+Math.cos(tipA)*tipR;
      const tipY2=flowerY+Math.sin(tipA)*tipR;
      const perpA=a+Math.PI/2;
      const bend=(rngFlower(seed,pi+81)-0.5)*outerR*0.28;
      const midX2=flowerX+Math.cos(a)*outerR*0.5+Math.cos(perpA)*bend;
      const midY2=flowerY+Math.sin(a)*outerR*0.5+Math.sin(perpA)*bend;
      const sw=outerR*(0.28+rngFlower(seed,pi+82)*0.08);
      // Shadow
      ctx.beginPath();ctx.moveTo(flowerX,flowerY);
      ctx.quadraticCurveTo(midX2,midY2,tipX2,tipY2);
      ctx.strokeStyle=withAlpha(color,0.32);ctx.lineWidth=sw*1.2;ctx.lineCap='round';ctx.stroke();
      // Main
      ctx.beginPath();ctx.moveTo(flowerX,flowerY);
      ctx.quadraticCurveTo(midX2,midY2,tipX2,tipY2);
      ctx.strokeStyle=withAlpha(color,0.92);ctx.lineWidth=sw;ctx.stroke();
    });
  });

  // Ribbon wrap at base
  ctx.save();ctx.translate(handX,handY-6);
  ctx.beginPath();ctx.ellipse(0,0,16,8,0,0,Math.PI*2);
  ctx.strokeStyle='rgba(180,155,130,0.55)';ctx.lineWidth=2.5;ctx.stroke();ctx.restore();

  // Stats
  const totalBlooms=activeDays.reduce((a,d)=>{
    const e=log[d.iso]||[];const seen=new Set();
    pursuits.forEach(p=>{if(e.some(tid=>(typeof tid==='string'?tid:tid.tid)===p.id))seen.add(p.id)});
    return a+seen.size;
  },0);
  document.getElementById('garden-stat').textContent=`${totalBlooms} blooms · ${activeDays.length} days`;

  // Title
  const titleEl=document.getElementById('garden-title');
  if(titleEl){
    if(gardenSpan==='week')titleEl.textContent='This week';
    else if(gardenSpan==='month')titleEl.textContent=MONTHS[viewMonth]+' '+viewYear;
    else titleEl.textContent='Your garden';
  }
}

function saveGarden(){
  const canvas=document.getElementById('garden-canvas');
  if(!canvas)return;
  const a=document.createElement('a');a.download='strata-garden.png';a.href=canvas.toDataURL();a.click();
}

function init(){
  // Build onboarding list
  document.getElementById('onboard-list').innerHTML=pursuits.map(p=>`<div class="onboard-pursuit"><div class="onboard-dot" style="background:${p.color}"></div><span style="font-family:var(--mono);font-size:12px;font-weight:500">${p.label}</span></div>`).join('');
  renderSidebar();
  // Set initial active states
  document.querySelectorAll('[data-style]').forEach(b=>b.classList.toggle('active',b.dataset.style===currentStyle));
  document.querySelectorAll('[data-comp]').forEach(b=>b.classList.toggle('active',b.dataset.comp===artComp));
  document.querySelectorAll('[data-span]').forEach(b=>b.classList.toggle('active',b.dataset.span==artSpan));
  buildBgSwatches();
  // Auto-dismiss onboarding if returning user
  if(localStorage.getItem('sp_seen')){dismissOnboarding()}
  else{localStorage.setItem('sp_seen','1')}
  // Resize handler for art canvas
  window.addEventListener('resize',()=>{if(currentView==='art')redrawArt();if(currentView==='garden')renderGarden()});
}
init();
