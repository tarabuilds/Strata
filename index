// =======================================================
// FLOWER SVG RENDERER
// =======================================================
function flowerSVG(petals,s,seed){
  if(!petals||!petals.length)return'';
  s=s||20;const style=currentStyle;
  const n=petals.length,cx=s/2,cy=s/2;
  if(!seed)seed=n*31+7;
  const scaleD=n<=5?1:n<=8?0.88:n<=10?0.78:0.68;
  const outerR=s*0.42*scaleD,baseR=s*0.03;
  const maxSpread=Math.min(0.38,(Math.PI*0.72)/n);
  let svg=`<svg viewBox="0 0 ${s} ${s}" style="width:88%;height:88%;display:block">`;
  for(let i=0;i<n;i++){
    const a=(i/n)*Math.PI*2-Math.PI/2;
    const c=petals[i%n];
    const tipR=outerR*(0.90+rngFlower(seed,i)*0.18);
    const tipA=a+(rngFlower(seed,i+50)-0.5)*0.12;
    const tipX=cx+Math.cos(tipA)*tipR,tipY=cy+Math.sin(tipA)*tipR;
    const spread=maxSpread*(0.9+rngFlower(seed,i+20)*0.2);
    const lX=cx+Math.cos(a-spread)*baseR,lY=cy+Math.sin(a-spread)*baseR;
    const rX=cx+Math.cos(a+spread)*baseR,rY=cy+Math.sin(a+spread)*baseR;
    const bulgeR=outerR*(0.72+rngFlower(seed,i+40)*0.14);
    const bs=(rngFlower(seed,i+60)-0.5)*0.15;
    const cp1X=cx+Math.cos(a-spread*0.5+bs)*bulgeR,cp1Y=cy+Math.sin(a-spread*0.5+bs)*bulgeR;
    const cp2X=cx+Math.cos(a+spread*0.5+bs)*bulgeR,cp2Y=cy+Math.sin(a+spread*0.5+bs)*bulgeR;
    const perpA=a+Math.PI/2;
    if(style==='expressionist'){
      const bend=(rngFlower(seed,i+81)-0.5)*outerR*0.28;
      const midX=cx+Math.cos(a)*outerR*0.5+Math.cos(perpA)*bend;
      const midY=cy+Math.sin(a)*outerR*0.5+Math.sin(perpA)*bend;
      const sw=outerR*(0.28+rngFlower(seed,i+82)*0.08);
      svg+=`<path d="M ${cx.toFixed(1)},${cy.toFixed(1)} Q ${midX.toFixed(1)},${midY.toFixed(1)} ${tipX.toFixed(1)},${tipY.toFixed(1)}" fill="none" stroke="${c}" stroke-width="${(sw*1.2).toFixed(1)}" stroke-linecap="round" opacity="0.35"/>`;
      svg+=`<path d="M ${cx.toFixed(1)},${cy.toFixed(1)} Q ${midX.toFixed(1)},${midY.toFixed(1)} ${tipX.toFixed(1)},${tipY.toFixed(1)}" fill="none" stroke="${c}" stroke-width="${sw.toFixed(1)}" stroke-linecap="round" opacity="0.92"/>`;
      const hMx=midX+Math.cos(perpA)*sw*0.1,hMy=midY+Math.sin(perpA)*sw*0.1;
      svg+=`<path d="M ${(cx+Math.cos(perpA)*sw*0.1).toFixed(1)},${(cy+Math.sin(perpA)*sw*0.1).toFixed(1)} Q ${hMx.toFixed(1)},${hMy.toFixed(1)} ${(tipX+Math.cos(perpA)*sw*0.06).toFixed(1)},${(tipY+Math.sin(perpA)*sw*0.06).toFixed(1)}" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="${(sw*0.16).toFixed(1)}" stroke-linecap="round"/>`;
    } else if(style==='impressionist'){
      for(let d=0;d<6;d++){
        const t=0.15+d/7*0.75;
        const dA=a+(rngFlower(seed,i*20+d)-0.5)*spread*1.3;
        const dist=baseR+t*(outerR*0.9-baseR);
        const dx=cx+Math.cos(dA)*dist,dy=cy+Math.sin(dA)*dist;
        const dlen=s*(0.10+rngFlower(seed,i*20+d+5)*0.05);
        const dw=s*(0.024+rngFlower(seed,i*20+d+10)*0.010);
        const dAng=dA+Math.PI/2-0.8+(rngFlower(seed,i*20+d+15)-0.5)*0.4;
        svg+=`<line x1="${(dx-Math.cos(dAng)*dlen/2).toFixed(1)}" y1="${(dy-Math.sin(dAng)*dlen/2).toFixed(1)}" x2="${(dx+Math.cos(dAng)*dlen/2).toFixed(1)}" y2="${(dy+Math.sin(dAng)*dlen/2).toFixed(1)}" stroke="${c}" stroke-width="${dw.toFixed(1)}" stroke-linecap="round" opacity="${(0.55+rngFlower(seed,i*20+d+20)*0.35).toFixed(2)}"/>`;
      }
    } else if(style==='pointillist'){
      const rings=[{n:1,t:0.28,sz:1.0},{n:3,t:0.55,sz:0.82},{n:4,t:0.80,sz:0.60}];
      rings.forEach(({n:dn,t,sz})=>{
        const px=cx+Math.cos(a)*outerR*t,py=cy+Math.sin(a)*outerR*t;
        for(let d=0;d<dn;d++){
          const da=dn===1?0:(d/dn)*Math.PI*2+rngFlower(seed,i*30+d)*0.3;
          const dr=dn===1?0:s*0.032*(0.8+rngFlower(seed,i*30+d+5)*0.4);
          const dotR=s*(0.038+rngFlower(seed,i*30+d+10)*0.020)*sz;
          svg+=`<circle cx="${(px+Math.cos(da)*dr+(rngFlower(seed,i*30+d+15)-0.5)*s*0.018).toFixed(1)}" cy="${(py+Math.sin(da)*dr+(rngFlower(seed,i*30+d+16)-0.5)*s*0.018).toFixed(1)}" r="${Math.max(0.5,dotR).toFixed(1)}" fill="${c}" opacity="${(0.65+rngFlower(seed,i*30+d+20)*0.28).toFixed(2)}"/>`;
        }
      });
    } else if(style==='watercolour'){
      const layers=[{f:1.18,op:0.10},{f:1.0,op:0.18},{f:0.82,op:0.28},{f:0.64,op:0.40}];
      layers.forEach(({f,op})=>{
        svg+=`<path d="M ${lX.toFixed(1)},${lY.toFixed(1)} C ${(cp1X*f+cx*(1-f)).toFixed(1)},${(cp1Y*f+cy*(1-f)).toFixed(1)} ${(tipX*f+cx*(1-f)).toFixed(1)},${(tipY*f+cy*(1-f)).toFixed(1)} ${(tipX*f+cx*(1-f)).toFixed(1)},${(tipY*f+cy*(1-f)).toFixed(1)} C ${(tipX*f+cx*(1-f)).toFixed(1)},${(tipY*f+cy*(1-f)).toFixed(1)} ${(cp2X*f+cx*(1-f)).toFixed(1)},${(cp2Y*f+cy*(1-f)).toFixed(1)} ${rX.toFixed(1)},${rY.toFixed(1)} Z" fill="${c}" opacity="${op}"/>`;
      });
    } else {
      // inkwash
      const sc=saturateHex(c,1.6);
      const isp=spread*0.50;
      svg+=`<path d="M ${(cx+Math.cos(a-isp)*baseR).toFixed(1)},${(cy+Math.sin(a-isp)*baseR).toFixed(1)} C ${cp1X.toFixed(1)},${cp1Y.toFixed(1)} ${tipX.toFixed(1)},${tipY.toFixed(1)} ${tipX.toFixed(1)},${tipY.toFixed(1)} C ${tipX.toFixed(1)},${tipY.toFixed(1)} ${cp2X.toFixed(1)},${cp2Y.toFixed(1)} ${(cx+Math.cos(a+isp)*baseR).toFixed(1)},${(cy+Math.sin(a+isp)*baseR).toFixed(1)} Z" fill="${sc}" opacity="0.93"/>`;
      svg+=`<line x1="${tipX.toFixed(1)}" y1="${tipY.toFixed(1)}" x2="${(tipX*1.06+cx*(-0.06)).toFixed(1)}" y2="${(tipY*1.06+cy*(-0.06)).toFixed(1)}" stroke="rgba(255,255,255,0.38)" stroke-width="${(s*0.012).toFixed(1)}" stroke-linecap="round"/>`;
    }
  }
  svg+='</svg>';
  return svg;
}

