function getArtEntries(){
  const todayStr=todayIso();
  if(artSpan===0)return(log[todayStr]||[]).map((tid,i)=>({date:todayStr,tid:typeof tid==='string'?tid:tid.tid,color:taskColor(typeof tid==='string'?tid:tid.tid)}));
  if(artSpan===-1){const entries=[];for(let i=6;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);const iso=isoDate(d.getFullYear(),d.getMonth(),d.getDate());(log[iso]||[]).forEach(tid=>{entries.push({date:iso,tid:typeof tid==='string'?tid:tid.tid,color:taskColor(typeof tid==='string'?tid:tid.tid)})})}return entries}
  const allEntries=[];
  Object.keys(log).sort().forEach(date=>{
    const d=new Date(date+'T12:00:00');
    const mDiff=(viewYear-d.getFullYear())*12+(viewMonth-d.getMonth());
