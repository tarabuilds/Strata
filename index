<!DOCTYPE html>
<!-- Strata v3.0 rebuilt -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Strata">
<meta name="mobile-web-app-capable" content="yes">
<title>Strata</title>
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<link rel="apple-touch-icon" sizes="192x192" href="data:image/png;base64,">
<meta name="apple-touch-icon" content="data:image/png;base64,">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,400;0,600;0,900;1,300;1,400;1,600;1,900&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ===================================
   TOKENS
=================================== */
:root{
  --serif:'Fraunces',Georgia,serif;
  --mono:'DM Mono',monospace;
  --sidebar:230px;
  --bg:#faf8f4;
  --bg2:#f2ede4;
  --bg3:#e8e0d0;
  --ink:#18140e;
  --ink2:#4a3f30;
  --ink3:#9c8e7a;
  --border:#d8cfc0;
  --border2:#c8bfb0;
  --accent:#6b8f71;
  --accent-fg:#ffffff;
  --safe-t:env(safe-area-inset-top,0px);
  --safe-b:env(safe-area-inset-bottom,0px);
  --safe-l:env(safe-area-inset-left,0px);
  --safe-r:env(safe-area-inset-right,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{height:100%;height:-webkit-fill-available}
body{
  font-family:var(--mono);
  background:var(--bg);color:var(--ink);
  height:100%;height:-webkit-fill-available;
  overflow:hidden;
  -webkit-text-size-adjust:100%;
}

/* ===================================
   LAYOUT — shared desktop + mobile
=================================== */
.app{display:flex;height:100%;height:-webkit-fill-available;overflow:hidden}

/* ===================================
   SIDEBAR
=================================== */
.sidebar{
  width:var(--sidebar);flex-shrink:0;
  background:var(--bg);border-right:1.5px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
  height:100%;
}
.sidebar-stripe{height:5px;background:linear-gradient(to right,#e8452a,#f5c842,#3ab87a,#2e7dd6,#8b4fcf,#e8452a);flex-shrink:0}
.sidebar-head{padding:1.25rem 1.25rem 0.75rem;border-bottom:1.5px solid var(--border);flex-shrink:0}
.sidebar-wordmark{font-family:var(--serif);font-size:24px;font-weight:900;font-style:italic;color:var(--ink);letter-spacing:-0.5px;line-height:1}
.sidebar-tagline{font-size:7.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink3);margin-top:3px;font-family:var(--mono)}
.sidebar-dots{display:flex;gap:5px;flex-wrap:wrap;margin-top:10px}
.sidebar-body{flex:1;overflow-y:auto;overflow-x:hidden;padding:0}
.sidebar-section{padding:0.75rem 1.25rem;border-bottom:1.5px solid var(--border)}
.sidebar-label{font-size:7px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink3);font-weight:500;margin-bottom:7px;font-family:var(--mono)}
.sidebar-nav{display:flex;flex-direction:column;gap:1px}
.nav-item{
  display:flex;align-items:center;gap:9px;
  padding:7px 8px;border-radius:7px;cursor:pointer;
  font-size:12px;font-weight:500;color:var(--ink2);
  border:none;background:none;width:100%;text-align:left;
  font-family:var(--mono);
  transition:background 0.1s;
}
.nav-item:hover{background:var(--bg2)}
.nav-item.active{background:var(--accent);color:var(--accent-fg)}
.nav-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.task-list-sidebar{display:flex;flex-direction:column;gap:1px;margin-bottom:7px}
.task-row{display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:500;color:var(--ink2)}
.task-row:hover{background:var(--bg2)}
.task-swatch{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.style-btn{
  display:block;width:100%;text-align:left;
  padding:6px 8px;border-radius:7px;
  border:none;background:none;
  font-family:var(--mono);font-size:11px;font-weight:500;
  color:var(--ink2);cursor:pointer;
  transition:background 0.1s;
}
.style-btn:hover{background:var(--bg2)}
.style-btn.active{background:var(--accent);color:var(--accent-fg)}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:8px}
.stat-box{background:var(--bg2);border-radius:8px;padding:8px 10px;border:1px solid var(--border)}
.stat-val{font-family:var(--serif);font-size:20px;font-weight:600;color:var(--ink);line-height:1}
.stat-label{font-size:7px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink3);margin-top:2px;font-family:var(--mono)}
.add-btn{
  width:100%;padding:8px;border-radius:8px;
  border:1.5px dashed var(--border2);background:none;
  font-family:var(--mono);font-size:10px;
  color:var(--ink3);cursor:pointer;letter-spacing:0.06em;
  transition:all 0.15s;
}
.add-btn:hover{background:var(--bg2);color:var(--ink2)}
.palette-dot{
  width:16px;height:16px;border-radius:50%;cursor:pointer;flex-shrink:0;
  transition:transform 0.15s;
}

/* ===================================
   MAIN CONTENT
=================================== */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.view{display:none;flex:1;flex-direction:column;overflow:hidden;min-height:0;padding:1.5rem 1.75rem}
.view.active{display:flex}

/* Month */
.month-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;flex-shrink:0}
.month-title{font-family:var(--serif);font-size:36px;font-weight:900;font-style:italic;color:var(--ink);letter-spacing:-1px;line-height:1}
.month-nav-btns{display:flex;gap:6px}
.month-nav-btn{
  width:30px;height:30px;border-radius:50%;
  border:1.5px solid var(--accent);color:var(--accent);
  background:none;cursor:pointer;font-size:14px;
  display:flex;align-items:center;justify-content:center;
}
.rainbow-bar{height:4px;background:linear-gradient(to right,#e8452a,#f5813a,#f5c842,#a8d44a,#3ab87a,#2e9fd6,#2e7dd6,#6b52cf,#8b4fcf,#d44fcf,#e8452a);border-radius:2px;flex-shrink:0;margin-bottom:4px}
.cal-headers{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:2px;flex-shrink:0}
.cal-header-cell{text-align:center;font-size:8px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink3);padding:3px 0;font-family:var(--mono)}
.cal-grid{
  flex:1 1 0;min-height:0;
  display:grid;grid-template-columns:repeat(7,1fr);
  grid-auto-rows:1fr;gap:3px;
}
.cal-cell{
  background:var(--bg2);border-radius:7px;
  cursor:pointer;position:relative;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;min-height:0;
  border:1.5px solid transparent;
  transition:border-color 0.15s;
}
.cal-cell:hover{border-color:var(--border2)}
.cal-cell.today{border-color:var(--accent)}
.cal-cell.empty{background:transparent;cursor:default;border:none}
.day-num{position:absolute;top:3px;left:4px;font-size:7.5px;color:var(--ink3);font-family:var(--mono);font-weight:500;z-index:1}
.colour-row{display:flex;align-items:center;gap:8px;padding:0.4rem 0 0.1rem;flex-shrink:0;flex-wrap:wrap}
.colour-row-label{font-size:10px;font-family:var(--serif);color:var(--ink3);white-space:nowrap}

/* Year */
.year-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-shrink:0}
.year-title{font-family:var(--serif);font-size:36px;font-weight:900;font-style:italic;color:var(--ink);letter-spacing:-1px}
.year-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;overflow-y:auto;flex:1;min-height:0}
.mini-month{cursor:pointer}
.mini-month-title{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:5px;font-family:var(--mono)}
.mini-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.mini-cell{aspect-ratio:1;background:var(--bg2);border-radius:3px;cursor:pointer;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.mini-cell.today-mini{outline:1.5px solid var(--accent);outline-offset:-1px}
.mini-cell.empty-mini{background:transparent}

/* Art */
.art-view{display:none;flex:1;flex-direction:column;overflow:hidden;min-height:0}
.art-view.active{display:flex}
.art-top{padding:1rem 1.5rem 0.5rem;flex-shrink:0;display:flex;align-items:flex-end;justify-content:space-between}
.art-title-block small{display:block;font-size:8px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink3);font-family:var(--mono);margin-bottom:2px}
.art-title-block span{font-family:var(--serif);font-size:30px;font-weight:700;font-style:italic;color:var(--ink);letter-spacing:-0.5px}
#art-canvas-wrap{flex:1;min-height:0;margin:0 1rem 0.5rem;border-radius:12px;overflow:hidden;position:relative}
#art-canvas-wrap canvas{display:block;width:100%;height:100%}
.art-toolbar{background:var(--bg);border-top:1.5px solid var(--border);flex-shrink:0;padding:6px 0}
.art-row{display:flex;align-items:center;gap:5px;padding:3px 1rem;flex-wrap:wrap}
.art-lbl{font-size:7.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink3);flex-shrink:0;font-family:var(--mono)}
.art-pill{
  padding:3px 9px;border-radius:12px;font-size:8px;
  border:1px solid var(--border2);background:none;
  color:var(--ink2);cursor:pointer;white-space:nowrap;
  font-family:var(--mono);font-weight:500;
  transition:all 0.12s;
}
.art-pill:hover{background:var(--bg2)}
.art-pill.active{background:var(--accent);color:var(--accent-fg);border-color:transparent}
.art-sep{width:1px;height:16px;background:var(--border2);flex-shrink:0}
.art-action{
  padding:3px 10px;border-radius:12px;font-size:8px;
  border:1.5px solid var(--accent);color:var(--accent);
  background:none;cursor:pointer;font-family:var(--mono);font-weight:500;
  white-space:nowrap;
}
.art-slider{width:56px;height:3px;cursor:pointer;accent-color:var(--accent)}
.bg-btn-wrap{position:relative;display:flex;align-items:center;gap:4px}
.bg-pill{
  display:flex;align-items:center;padding:3px 6px;
  border-radius:12px;border:1.5px solid var(--border2);
  background:none;cursor:pointer;
}
.bg-rainbow{width:14px;height:14px;border-radius:50%;background:conic-gradient(#e8452a,#f5c842,#3ab87a,#2e7dd6,#8b4fcf,#e8452a);border:1px solid rgba(0,0,0,0.1)}
.bg-popover{
  display:none;position:fixed;bottom:70px;left:50%;transform:translateX(-50%);
  background:var(--bg);border:1px solid var(--border2);border-radius:12px;
  padding:12px;box-shadow:0 6px 28px rgba(0,0,0,0.16);z-index:200;width:260px;
}
.bg-popover-label{font-size:7.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink3);font-family:var(--mono);margin-bottom:9px}
.bg-swatches{display:flex;flex-wrap:wrap;gap:6px}
.bg-swatch{width:22px;height:22px;border-radius:5px;cursor:pointer;border:1.5px solid transparent;transition:transform 0.12s}
.bg-swatch:hover{transform:scale(1.15)}
.bg-swatch.active{outline:2.5px solid var(--accent);outline-offset:1.5px}
.art-hint{font-size:9px;color:var(--ink3);font-family:var(--mono);margin-left:auto}

/* Overlays */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:300;align-items:flex-end;justify-content:center}
.overlay.open{display:flex}
@media(min-width:600px){.overlay{align-items:center}}
.overlay-card{
  background:var(--bg);border-radius:16px 16px 0 0;
  width:100%;max-width:480px;max-height:90vh;overflow-y:auto;
  padding:1.5rem;padding-bottom:calc(1.5rem + var(--safe-b));
}
@media(min-width:600px){.overlay-card{border-radius:16px;margin:1rem}}
.overlay-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 1.25rem}
.overlay-title{font-family:var(--serif);font-size:24px;font-weight:700;font-style:italic;color:var(--ink);margin-bottom:1rem}
.log-date-display{font-size:11px;color:var(--ink3);font-family:var(--mono);margin-bottom:1rem}
.pursuit-btns{display:flex;flex-direction:column;gap:5px;margin-bottom:1rem}
.pursuit-log-btn{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;border-radius:9px;
  border:1.5px solid var(--border);background:none;
  cursor:pointer;font-family:var(--mono);font-size:12px;
  font-weight:500;color:var(--ink);text-align:left;
  transition:background 0.12s;
}
.pursuit-log-btn:hover{background:var(--bg2)}
.pursuit-log-btn.logged{background:var(--ink);color:var(--bg);border-color:transparent}
.log-count{margin-left:auto;font-size:9px;opacity:0.7}
.btn-row{display:flex;gap:8px;justify-content:flex-end;margin-top:0.75rem}
.btn{padding:8px 16px;border-radius:8px;font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:0.06em;cursor:pointer;border:none}
.btn-primary{background:var(--ink);color:var(--bg)}
.btn-ghost{background:none;border:1.5px solid var(--border);color:var(--ink2)}
.edit-list{display:flex;flex-direction:column;gap:6px;margin-bottom:1rem}
.edit-row{display:flex;align-items:center;gap:8px}
.edit-input{flex:1;padding:7px 10px;border-radius:7px;border:1.5px solid var(--border);background:var(--bg);font-family:var(--mono);font-size:12px;color:var(--ink)}
.edit-input:focus{outline:none;border-color:var(--accent)}
.swatch-pick{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px}
.sp{width:18px;height:18px;border-radius:50%;cursor:pointer;flex-shrink:0}
.remove-btn{background:none;border:none;color:var(--ink3);font-size:18px;cursor:pointer;line-height:1;padding:0 2px;flex-shrink:0}

/* Onboarding */
#onboarding{
  display:none;position:fixed;inset:0;
  background:var(--bg);z-index:500;
  overflow-y:auto;
  padding:2rem 1.5rem calc(2rem + var(--safe-b));
}
#onboarding.open{display:block}
.onboard-inner{max-width:420px;margin:0 auto}
.onboard-title{font-family:var(--serif);font-size:52px;font-weight:900;font-style:italic;color:var(--ink);letter-spacing:-2px;line-height:0.95;margin-bottom:0.5rem}
.onboard-sub{font-size:16px;color:var(--ink2);line-height:1.7;margin-bottom:2rem;font-family:var(--serif);font-style:italic}
.onboard-pursuits{display:flex;flex-direction:column;gap:6px;margin-bottom:2.5rem}
.onboard-pursuit{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg2);border-radius:9px}
.onboard-dot{width:10px;height:10px;border-radius:50%}
.onboard-start{
  width:100%;padding:14px;border-radius:10px;
  background:var(--ink);color:var(--bg);
  font-family:var(--mono);font-size:12px;font-weight:500;
  letter-spacing:0.08em;border:none;cursor:pointer;
  transition:opacity 0.15s;
}
.onboard-start:hover{opacity:0.8}

/* Scrollbar */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg3);border-radius:3px}

/* Mobile — phones only */
@media(max-width:700px){
  /* Full-height PWA layout */
  .app{flex-direction:column}
  .sidebar{
    /* On mobile: full-width top bar instead */
    width:100%;height:auto;border-right:none;
    border-bottom:1.5px solid var(--border);
    flex-direction:row;align-items:center;
    padding:calc(var(--safe-t) + 6px) 1rem 6px;
    flex-shrink:0;overflow:visible;
  }
  .sidebar-stripe{display:none}
  .sidebar-head{padding:0;border:none;flex:1;display:flex;align-items:center;gap:10px}
  .sidebar-wordmark{font-size:20px}
  .sidebar-tagline{display:none}
  .sidebar-dots{margin:0;flex-wrap:nowrap;overflow-x:auto;max-width:50vw;gap:4px}
  .sidebar-dots::-webkit-scrollbar{display:none}
  .palette-dot{width:14px;height:14px}
  .sidebar-body{display:none}  /* hidden — use hamburger drawer instead */

  /* Hamburger button */
  .sidebar-hamburger{
    display:flex;flex-direction:column;gap:4px;
    background:none;border:none;cursor:pointer;padding:4px;margin-right:6px;
    flex-shrink:0;
  }
  .sidebar-hamburger span{display:block;width:18px;height:1.5px;background:var(--ink);border-radius:2px}

  /* Main fills remaining height */
  .main{flex:1;min-height:0}
  .view{padding:0.75rem 0.75rem 0.5rem}
  .view.active{display:flex}

  /* Month tweaks */
  .month-title{font-size:26px}
  .cal-cell{border-radius:5px}
  .day-num{font-size:6.5px;top:2px;left:3px}
  .year-grid{grid-template-columns:repeat(2,1fr);gap:0.75rem}

  /* Art */
  #art-canvas-wrap{margin:0 0.5rem 0.25rem;border-radius:8px}
  .art-top{padding:0.5rem 0.75rem 0.25rem}
  .art-title-block span{font-size:22px}
  .art-title-block small{display:none}
  .art-row{gap:3px;padding:2px 0.75rem}
  .art-row:not(:first-child){overflow-x:auto;flex-wrap:nowrap}
  .art-row::-webkit-scrollbar{display:none}

  /* Drawer */
  .drawer-overlay{
    display:none;position:fixed;inset:0;
    background:rgba(0,0,0,0.45);z-index:400;
  }
  .drawer-overlay.open{display:block}
  .drawer{
    position:fixed;top:0;left:0;bottom:0;
    width:270px;background:var(--bg);
    z-index:401;
    transform:translateX(-100%);
    transition:transform 0.26s cubic-bezier(0.4,0,0.2,1);
    display:flex;flex-direction:column;
    box-shadow:4px 0 24px rgba(0,0,0,0.15);
    overflow:hidden;
  }
  .drawer.open{transform:translateX(0)}
  .drawer-stripe{height:4px;background:linear-gradient(to right,#e8452a,#f5c842,#3ab87a,#2e7dd6,#8b4fcf,#e8452a);flex-shrink:0}
  .drawer-head{
    padding:calc(var(--safe-t) + 1rem) 1.25rem 0.75rem;
    border-bottom:1px solid var(--border);flex-shrink:0;
  }
  .drawer-wordmark{font-family:var(--serif);font-size:22px;font-weight:900;font-style:italic;color:var(--ink);letter-spacing:-0.5px}
  .drawer-tagline{font-size:7px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink3);margin-top:2px;font-family:var(--mono)}
  .drawer-dots{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}
  .drawer-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch}
  .drawer-section{padding:0.75rem 1.25rem;border-bottom:1px solid var(--border)}
  .drawer-section-label{font-size:7px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink3);font-weight:500;margin-bottom:7px;font-family:var(--mono)}
  .drawer-nav-item{
    display:flex;align-items:center;gap:8px;
    padding:7px 8px;border-radius:7px;cursor:pointer;
    font-size:12px;font-weight:500;color:var(--ink2);
    border:none;background:none;width:100%;text-align:left;
    font-family:var(--mono);
  }
  .drawer-nav-item:hover{background:var(--bg2)}
  .drawer-nav-item.active{background:var(--accent);color:var(--accent-fg)}

  /* colour row on month page */
  .colour-row{padding:0.3rem 0 0.1rem}
  .colour-row-label{font-size:9px}
}
/* Desktop: hide mobile-only elements */
@media(min-width:701px){
  .sidebar-hamburger{display:none}
  .drawer,.drawer-overlay{display:none !important}
}
</style>
</head>
<body>

<!-- Onboarding -->
<div id="onboarding" class="open">
  <div class="onboard-inner">
    <div class="onboard-title">Strata</div>
    <div style="font-size:9px;font-family:var(--mono);color:var(--ink3);letter-spacing:0.1em;margin-bottom:0.25rem">v3.0</div>
    <div class="onboard-sub">Track your daily pursuits.<br>Watch them build into art, layer by layer.</div>
    <div class="onboard-pursuits" id="onboard-list"></div>
    <button class="onboard-start" onclick="dismissOnboarding()">Get started →</button>
  </div>
</div>

<!-- Mobile drawer overlay + drawer -->
<div class="drawer-overlay" id="drawer-overlay" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div class="drawer-stripe"></div>
  <div class="drawer-head">
    <div class="drawer-wordmark">Strata</div>
    <div class="drawer-tagline">where life becomes art</div>
    <div class="drawer-dots" id="drawer-dots"></div>
  </div>
  <div class="drawer-body">
    <div class="drawer-section">
      <div class="drawer-section-label">Navigate</div>
      <div id="drawer-nav"></div>
    </div>
    <div class="drawer-section">
