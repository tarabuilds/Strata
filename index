  });
  return allEntries;
}

function paintMark(ctx,cx,cy,W,H,color,rng,intensity){
  const style=currentStyle;
  ctx.save();
  if(style==='expressionist'){
    const len=H*(0.72+rng()*0.22),w=Math.max(4,W*0.44*(0.78+rng()*0.28));
    const ang=(rng()-0.5)*Math.PI*2;
    ctx.translate(cx,cy);ctx.rotate(ang);
    const bend=(rng()-0.5)*w*0.55,bend2=(rng()-0.5)*w*0.45;
    ctx.beginPath();ctx.moveTo(bend,-len/2);ctx.bezierCurveTo(bend,-len*0.18,bend2,len*0.18,bend2,len/2);
    ctx.strokeStyle=withAlpha(varyColor(rng,color,0.04),0.35);ctx.lineWidth=w*1.05;ctx.lineCap='round';ctx.stroke();
    ctx.strokeStyle=withAlpha(varyColor(rng,color,0.04),0.92);ctx.lineWidth=w;ctx.stroke();
    ctx.beginPath();ctx.moveTo(bend*0.3+w*0.08,-len*0.40);ctx.lineTo(bend2*0.3-w*0.04,len*0.40);
    ctx.strokeStyle='rgba(255,255,255,0.50)';ctx.lineWidth=w*0.12;ctx.stroke();
  } else if(style==='impressionist'){
    const ns=3+Math.round(rng()*3);
    for(let d=0;d<ns;d++){
      const ox=(rng()-0.5)*W*0.55,oy=(rng()-0.5)*H*0.55;
      const sl=H*(0.22+rng()*0.28),sw=Math.max(2,W*(0.18+rng()*0.16));
      const sa=(rng()-0.5)*Math.PI*2;
      ctx.save();ctx.translate(cx+ox,cy+oy);ctx.rotate(sa);
      ctx.beginPath();
      for(let t=0;t<=8;t++){const tt=t/8,wt=sw*Math.sin(tt*Math.PI)*(0.7+rng()*0.3);const py=-sl/2+sl*tt;if(t===0){ctx.moveTo(-wt/2,py)}else{ctx.lineTo(-wt/2,py)}}
      for(let t=8;t>=0;t--){const tt=t/8,wt=sw*Math.sin(tt*Math.PI)*(0.7+rng()*0.3);ctx.lineTo(wt/2,-sl/2+sl*tt);}
      ctx.closePath();ctx.fillStyle=withAlpha(varyColor(rng,color,0.12),(0.50+rng()*0.30)*intensity);ctx.fill();
      ctx.restore();
    }
  } else if(style==='pointillist'){
    const rings=[{n:1,dist:0,sz:1.0},{n:4,dist:0.55,sz:0.78},{n:6,dist:1.1,sz:0.56}];
    const mr=Math.max(2,W*0.14);
    rings.forEach(({n,dist,sz})=>{
      for(let d=0;d<n;d++){
        const t=n===1?0:(d/n)*Math.PI*2+rng()*0.3;
        const jx=(rng()-0.5)*mr*0.25,jy=(rng()-0.5)*mr*0.25;
        const dx=cx+Math.cos(t)*mr*dist+jx,dy=cy+Math.sin(t)*mr*dist+jy;
        const dr=mr*sz*(0.7+rng()*0.5);
        ctx.beginPath();ctx.arc(dx,dy,Math.max(0.8,dr),0,Math.PI*2);
        ctx.fillStyle=withAlpha(varyColor(rng,color,0.08),(0.55+intensity*0.40)+rng()*0.15);ctx.fill();
      }
    });
  } else if(style==='watercolour'){
    const bW=W*(0.65+rng()*0.30),bH=H*(0.48+rng()*0.22);
    const ang=(rng()-0.5)*Math.PI;
    ctx.translate(cx,cy);ctx.rotate(ang);
    [[0.55,0.45,0.44],[0.48,0.48,0.60],[0.38,0.45,0.68],[0.28,0.42,0.78]].forEach(([rx,ry,op])=>{
      ctx.beginPath();ctx.ellipse(rng()*bW*0.06,rng()*bH*0.06,bW*rx,bH*ry,0,0,Math.PI*2);
      ctx.fillStyle=withAlpha(varyColor(rng,color,0.08),op*intensity);ctx.fill();
    });
  } else {
    // inkwash
    const len=H*(0.62+rng()*0.28),w=Math.max(3,W*0.30*(0.85+rng()*0.25));
    const ang=(rng()-0.5)*Math.PI*2;
    ctx.translate(cx,cy);ctx.rotate(ang);
    const sc=saturateHex(color,1.7);
    const ns=16;
    ctx.beginPath();
    for(let t=0;t<=ns;t++){const tt=t/ns,py=-len/2+len*tt,wt=w*Math.sin(tt*Math.PI)*(0.85+rng()*0.3),px=(rng()-0.5)*wt*0.15;t===0?ctx.moveTo(px-wt/2,py):ctx.lineTo(px-wt/2,py)}
    for(let t=ns;t>=0;t--){const tt=t/ns,py=-len/2+len*tt,wt=w*Math.sin(tt*Math.PI)*(0.85+rng()*0.3),px=(rng()-0.5)*wt*0.15;ctx.lineTo(px+wt/2,py)}
    ctx.closePath();ctx.fillStyle=withAlpha(sc,0.88+intensity*0.10);ctx.fill();
    for(let h=0;h<3;h++){ctx.beginPath();ctx.moveTo((rng()-0.5)*w*0.3,-len*0.4-rng()*len*0.1);ctx.lineTo((rng()-0.5)*w*0.5,-len*0.52);ctx.strokeStyle='rgba(255,255,255,0.30)';ctx.lineWidth=0.5+rng()*0.7;ctx.lineCap='round';ctx.stroke()}
  }
  ctx.restore();
}

function shapePoint(comp,rng){
  const R=Math.min(W,H)*0.44,cx=W/2,cy=H/2;
  switch(comp){
    case 'circle':{const a=rng()*Math.PI*2,r=R*Math.sqrt(rng());return{x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r}}
    case 'star':{for(let i=0;i<8;i++){const a=rng()*Math.PI*2,sec=Math.floor((a+Math.PI/2)/(Math.PI*2/5));const oA=(sec/5)*Math.PI*2-Math.PI/2,iA=oA+Math.PI/5;if(rng()<0.35){const t=rng();return{x:cx+Math.cos(oA)*R*(1-t)+Math.cos(iA)*R*0.40*t,y:cy+Math.sin(oA)*R*(1-t)+Math.sin(iA)*R*0.40*t}};const r=R*(0.40+rng()*0.60);return{x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r}}return{x:cx,y:cy}}
    case 'sun':{if(rng()<0.50){const a=rng()*Math.PI*2,r=R*0.36*Math.sqrt(rng());return{x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r}};const ri=Math.floor(rng()*8),rA=(ri/8)*Math.PI*2-Math.PI/2,al=R*0.38+rng()*R*0.50,aw=(rng()-0.5)*R*0.09;return{x:cx+Math.cos(rA)*al+Math.cos(rA+Math.PI/2)*aw,y:cy+Math.sin(rA)*al+Math.sin(rA+Math.PI/2)*aw}}
    case 'heart':{for(let i=0;i<10;i++){const hx=(rng()*2-1)*R*0.92,hy=(rng()*2-1)*R*0.92,nx=hx/(R*0.55),ny=-hy/(R*0.55)+0.2;if(Math.pow(nx*nx+ny*ny-1,3)<=nx*nx*Math.pow(ny,3))return{x:cx+hx,y:cy+hy}};return{x:cx+(rng()-0.5)*R*0.5,y:cy+(rng()-0.5)*R*0.5}}
    case 'moon':{for(let i=0;i<12;i++){const a=rng()*Math.PI*2,r=R*(0.3+rng()*0.7),px=cx+Math.cos(a)*r,py=cy+Math.sin(a)*r;if(Math.sqrt(Math.pow(px-cx-R*0.38,2)+Math.pow(py-cy,2))>R*0.80&&r<R)return{x:px,y:py}};return{x:cx-R*0.3+(rng()-0.5)*R*0.3,y:cy+(rng()-0.5)*R*0.6}}
    case 'tree':{if(rng()<0.14)return{x:cx+(rng()-0.5)*R*0.16,y:cy+R*(0.35+rng()*0.48)};const lv=rng();return{x:cx+(rng()*2-1)*R*0.82*lv,y:cy-R*0.48+lv*R*0.92}}
    case 'diamond':{for(let i=0;i<6;i++){const px=(rng()*2-1)*R,py=(rng()*2-1)*R;if(Math.abs(px)+Math.abs(py)<=R*0.96)return{x:cx+px,y:cy+py}};return{x:cx,y:cy}}
    default:return{x:cx+(rng()-0.5)*R*1.8,y:cy+(rng()-0.5)*R*1.8}
  }
}

let W=0,H=0;
function redrawArt(){
  const canvas=document.getElementById('art-canvas');
  const wrap=document.getElementById('art-canvas-wrap');
  if(!canvas||!wrap)return;
  const dpr=window.devicePixelRatio||1;
  W=wrap.clientWidth;H=wrap.clientHeight;
  if(W<10||H<10)return;
  canvas.width=W*dpr;canvas.height=H*dpr;
  canvas.style.width=W+'px';canvas.style.height=H+'px';
  const ctx=canvas.getContext('2d');
  ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle=artBg;ctx.fillRect(0,0,W,H);
  const entries=getArtEntries();
  const total=entries.length;
  if(!total){document.getElementById('art-hint').textContent='No entries';return}
  document.getElementById('art-hint').textContent=`${total} marks · ${currentStyle}`;
  const intensity=parseFloat(document.getElementById('art-opacity').value||0.7);
  const scale=parseFloat(document.getElementById('art-size').value||1);
  const markW=Math.min(W,H)*0.09*scale;
  const markH=markW*0.9;
  const cx=W/2,cy=H/2,R=Math.min(W,H)*0.44;
  // Date → t mapping
  const allDates=[...new Set(entries.map(e=>e.date))].sort();
  const nD=Math.max(allDates.length-1,1);
  const dateT={};allDates.forEach((d,i)=>{dateT[d]=i/nD});
  const N=Math.max(pursuits.length,1);
  // Draw
  const shapes=['circle','star','sun','heart','moon','tree','diamond'];
  const isShape=shapes.includes(artComp);
  entries.forEach((e,i)=>{
    const rng=makeRng(baseSeed^(i*6271));
    const rng2=makeRng(baseSeed^(i*9137+31));
    const t=dateT[e.date]??0;
    let px,py;
    if(isShape){const pt=shapePoint(artComp,rng2);px=pt.x;py=pt.y}
    else if(artComp==='flow'){
      const tIdx=pursuits.findIndex(p=>p.id===e.tid);const laneH=H/(N+1);
      px=W*(0.05+0.90*t)+(rng()-0.5)*W*0.012;
      py=(tIdx+1)*laneH+Math.sin(t*Math.PI*3+tIdx*1.2)*laneH*0.25+(rng()-0.5)*laneH*0.15;
    } else if(artComp==='radial'){
      const tIdx=pursuits.findIndex(p=>p.id===e.tid);const sa=(Math.PI*2)/N;const ba=tIdx*sa-Math.PI/2;const ang=ba+(rng()-0.5)*sa*0.55;const r=R*0.08+(R*0.92)*t+(rng()-0.5)*R*0.04;px=cx+Math.cos(ang)*r;py=cy+Math.sin(ang)*r;
    } else if(artComp==='timeline'){
      const tIdx=pursuits.findIndex(p=>p.id===e.tid);const bH=H/(N+1);px=W*(0.05+0.90*t)+(rng()-0.5)*W*0.018;py=(tIdx+1)*bH+(rng()-0.5)*bH*0.22;
    } else if(artComp==='spiral'){
      const turns=Math.max(2,Math.min(8,total/5));const ang=-Math.PI/2+turns*Math.PI*2*t;const r=R*0.08+(R*0.92)*t;px=cx+Math.cos(ang)*r;py=cy+Math.sin(ang)*r;
    } else if(artComp==='grid'){
      const cols=Math.ceil(Math.sqrt(total*1.2));const cW=W/cols,cH=H/Math.max(Math.ceil(total/cols),1);const col=i%cols,row=Math.floor(i/cols);px=(col+0.5)*cW+(rng()-0.5)*cW*0.25;py=(row+0.5)*cH+(rng()-0.5)*cH*0.25;
    } else if(artComp==='wave'){
      const tIdx=pursuits.findIndex(p=>p.id===e.tid);const freq=1.5+tIdx*0.7;const amp=H*(0.10+tIdx*0.04);const baseY=H*0.5+Math.sin((tIdx/N)*Math.PI*2)*H*0.28;px=W*(0.04+0.92*t)+(rng()-0.5)*W*0.01;py=baseY+Math.sin(t*Math.PI*2*freq+(tIdx/N)*Math.PI)*amp+(rng()-0.5)*amp*0.2;
    } else if(artComp==='scatter'){
      const tIdx=pursuits.findIndex(p=>p.id===e.tid);const cols2=Math.ceil(Math.sqrt(N)),rows2=Math.ceil(N/cols2);const col=tIdx%cols2,row=Math.floor(tIdx/cols2);const hx=(col+0.5)/cols2,hy=(row+0.5)/rows2;const spr=Math.min(W,H)*(0.10+0.18*t);px=hx*W+(rng()-0.5)*spr;py=hy*H+(rng()-0.5)*spr;
    } else if(artComp==='vortex'){
      const ang=t*Math.PI*2*6+(pursuits.findIndex(p=>p.id===e.tid)/N)*Math.PI*2;const r=R*0.08+(R*0.88)*(1-t);px=cx+Math.cos(ang)*r+(rng()-0.5)*R*0.05;py=cy+Math.sin(ang)*r+(rng()-0.5)*R*0.05;
    } else {px=cx+(rng()-0.5)*R*1.8;py=cy+(rng()-0.5)*R*1.8}
    px=Math.max(markW,Math.min(W-markW,px));py=Math.max(markH,Math.min(H-markH,py));
    paintMark(ctx,px,py,markW,markH,e.color,rng,intensity);
  });
  updateArtLabel();
}
function repaintArt(){baseSeed=Math.floor(Math.random()*99999);redrawArt()}
function saveArt(){
  const canvas=document.getElementById('art-canvas');
  const a=document.createElement('a');a.download='strata-art.png';a.href=canvas.toDataURL();a.click();
}

