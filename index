function renderMonthView(){
  const fd=new Date(viewYear,viewMonth,1).getDay();
  const dim=new Date(viewYear,viewMonth+1,0).getDate();
  const todayStr=todayIso();
  document.getElementById('month-title').textContent=new Date(viewYear,viewMonth,1).toLocaleDateString('en-GB',{month:'long',year:'numeric'});
  document.getElementById('cal-headers').innerHTML=DAYS.map(d=>`<div class="cal-header-cell">${d}</div>`).join('');
  let html='';
  for(let i=0;i<fd;i++)html+=`<div class="cal-cell empty"></div>`;
  for(let d=1;d<=dim;d++){
    const iso=isoDate(viewYear,viewMonth,d);
    const entries=log[iso]||[];
    const isToday=iso===todayStr;
    const seen=new Set();const petals=[];
    pursuits.forEach(p=>{
      entries.forEach(tid=>{
        if((typeof tid==='string'?tid:tid.tid)===p.id)petals.push(p.color);
      });
    });
    // dedupe for flower (one petal per pursuit type)
    const petalsSeen=new Set();const uniquePetals=[];
    pursuits.forEach(p=>{if(entries.some(tid=>(typeof tid==='string'?tid:tid.tid)===p.id)&&!petalsSeen.has(p.id)){petalsSeen.add(p.id);uniquePetals.push(p.color)}});
    const daySeed=viewYear*10000+viewMonth*100+d;
    html+=`<div class="cal-cell${isToday?' today':''}" onclick="openLog('${iso}')"><span class="day-num">${d}</span>${uniquePetals.length?flowerSVG(uniquePetals,20,daySeed):''}</div>`;
  }
  document.getElementById('cal-grid').innerHTML=html;
}
function shiftMonth(d){viewMonth+=d;if(viewMonth<0){viewMonth=11;viewYear--}if(viewMonth>11){viewMonth=0;viewYear++}renderMonthView()}
function shiftYear(d){viewYearPage+=d;renderYearView()}

function renderYearView(){
  document.getElementById('year-title').textContent=viewYearPage;
  const todayStr=todayIso();
  let html='';
  for(let m=0;m<12;m++){
    const mName=new Date(viewYearPage,m,1).toLocaleDateString('en-GB',{month:'short'});
    const fd=new Date(viewYearPage,m,1).getDay();
    const dim=new Date(viewYearPage,m+1,0).getDate();
    html+=`<div class="mini-month" onclick="viewYear=${viewYearPage};viewMonth=${m};showView('month')"><div class="mini-month-title">${mName}</div><div class="mini-grid">`;
    for(let i=0;i<fd;i++)html+=`<div class="mini-cell empty-mini"></div>`;
    for(let d=1;d<=dim;d++){
      const iso=isoDate(viewYearPage,m,d);
      const hasLog=(log[iso]||[]).length>0;
      const isT=iso===todayStr;
      const petalsSeen=new Set();const up=[];
      if(hasLog)pursuits.forEach(p=>{if((log[iso]||[]).some(tid=>(typeof tid==='string'?tid:tid.tid)===p.id)&&!petalsSeen.has(p.id)){petalsSeen.add(p.id);up.push(p.color)}});
      const seed=viewYearPage*10000+m*100+d;
      html+=`<div class="mini-cell${isT?' today-mini':''}">${up.length?flowerSVG(up,14,seed):''}</div>`;
    }
    html+=`</div></div>`;
  }
  document.getElementById('year-grid').innerHTML=html;
}

