}
function buildGlobalSeq(){
  const seq=[];
  Object.keys(log).sort().forEach(date=>{
    (log[date]||[]).forEach(tid=>{seq.push({date,tid,color:taskColor(tid)})});
  });
  return seq;
}
function taskColor(tid){const t=pursuits.find(p=>p.id===tid);return t?t.color:'#888'}

// =======================================================
// SIDEBAR & DRAWER
// =======================================================
function renderSidebar(){
