function openLog(iso){
  logDate=iso;
  logSeq=[...( log[iso]||[])];
  document.getElementById('log-title').textContent='Log pursuits';
  const d=new Date(iso+'T12:00:00');
  document.getElementById('log-date-display').textContent=d.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  renderLogBtns();
  document.getElementById('log-panel').classList.add('open');
}
function renderLogBtns(){
  const counts={};(logSeq||[]).forEach(tid=>{counts[typeof tid==='string'?tid:tid.tid]=(counts[typeof tid==='string'?tid:tid.tid]||0)+1});
  document.getElementById('pursuit-btns').innerHTML=pursuits.map(function(p){
    const cnt=counts[p.id]||0;
    const logged=cnt>0?' logged':'';
    const countSpan=cnt>0?'<span class="log-count">×'+cnt+'</span>':'';
    return '<button class="pursuit-log-btn'+logged+'" data-tid="'+p.id+'"><span style="width:10px;height:10px;border-radius:50%;background:'+p.color+';flex-shrink:0"></span><span>'+p.label+'</span>'+countSpan+'</button>';
  }).join('');
  document.querySelectorAll('.pursuit-log-btn').forEach(function(btn){
    btn.onclick=function(){toggleLogPursuit(btn.dataset.tid)};
  });
}
function toggleLogPursuit(tid){logSeq.push(tid);renderLogBtns()}
function closeLog(){logDate=null;logSeq=[];document.getElementById('log-panel').classList.remove('open')}
function saveLog(){
  if(logDate){
    if(logSeq.length)log[logDate]=[...logSeq];
    else delete log[logDate];
    save();
  }
  closeLog();
  if(currentView==='month')renderMonthView();
  if(currentView==='year')renderYearView();
  renderSidebar();
}

